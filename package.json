{
  "name": "chronoarchive",
  "displayName": "ChronoArchive",
  "description": "Language support for chronoarchive (.car) files - structured task tracking with syntax highlighting, folding, and diagnostics",
  "version": "1.1.1",
  "publisher": "lenik",
  "repository": {
    "type": "git",
    "url": "https://github.com/lenik/chronoarchive.git"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets"
  ],
  "activationEvents": [
    "onLanguage:chronoarchive",
    "onCommand:chronoarchive.openDailyLog"
  ],
  "main": "./dist/extension.js",
  "icon": "icons/icon.png",
  "contributes": {
    "languages": [
      {
        "id": "chronoarchive",
        "aliases": [
          "ChronoArchive",
          "chronoarchive"
        ],
        "extensions": [
          ".car"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/icon-light.svg",
          "dark": "./icons/icon-dark.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "chronoarchive",
        "scopeName": "source.chronoarchive",
        "path": "./syntaxes/chronoarchive.tmLanguage.json"
      }
    ],
    "semanticTokenTypes": [
      {
        "id": "flag",
        "description": "Flags in chronoarchive head lines (e.g., 📝, ✅, TODO)"
      },
      {
        "id": "datetime",
        "description": "Date and time tokens in head lines"
      },
      {
        "id": "modifier",
        "description": "Modifiers in head lines (e.g., /prompt, /php, /lang=python)"
      },
      {
        "id": "attributeName",
        "description": "Attribute names in superheaders and item attributes"
      },
      {
        "id": "attributeValue",
        "description": "Attribute values in superheaders and item attributes"
      }
    ],
    "semanticTokenScopes": [
      {
        "language": "chronoarchive",
        "scopes": {
          "flag": [
            "keyword.control.chronoarchive"
          ],
          "datetime": [
            "constant.numeric.chronoarchive"
          ],
          "modifier": [
            "entity.other.attribute-name.chronoarchive"
          ],
          "attributeName": [
            "variable.other.chronoarchive"
          ],
          "attributeValue": [
            "string.unquoted.chronoarchive"
          ]
        }
      }
    ],
    "commands": [
      {
        "command": "chronoarchive.toggleDone",
        "title": "Toggle Done Flag",
        "category": "ChronoArchive"
      },
      {
        "command": "chronoarchive.toggleIgnored",
        "title": "Toggle Ignored Flag",
        "category": "ChronoArchive"
      },
      {
        "command": "chronoarchive.toggleExclamation",
        "title": "Toggle Exclamation Flag",
        "category": "ChronoArchive"
      },
      {
        "command": "chronoarchive.setPriority1",
        "title": "Set Priority 1 Star",
        "category": "ChronoArchive"
      },
      {
        "command": "chronoarchive.setPriority2",
        "title": "Set Priority 2 Stars",
        "category": "ChronoArchive"
      },
      {
        "command": "chronoarchive.setPriority3",
        "title": "Set Priority 3 Stars",
        "category": "ChronoArchive"
      },
      {
        "command": "chronoarchive.setPriority4",
        "title": "Set Priority 4 Stars",
        "category": "ChronoArchive"
      },
      {
        "command": "chronoarchive.setPriority5",
        "title": "Set Priority 5 Stars",
        "category": "ChronoArchive"
      },
      {
        "command": "chronoarchive.moveItemUp",
        "title": "Move Item Up",
        "category": "ChronoArchive"
      },
      {
        "command": "chronoarchive.moveItemDown",
        "title": "Move Item Down",
        "category": "ChronoArchive"
      },
      {
        "command": "chronoarchive.moveLineUp",
        "title": "Move Line Up",
        "category": "ChronoArchive"
      },
      {
        "command": "chronoarchive.moveLineDown",
        "title": "Move Line Down",
        "category": "ChronoArchive"
      },
      {
        "command": "chronoarchive.addItemAfter",
        "title": "Add Item After Current",
        "category": "ChronoArchive"
      },
      {
        "command": "chronoarchive.addItemBefore",
        "title": "Add Item Before Current",
        "category": "ChronoArchive"
      },
      {
        "command": "chronoarchive.addItemAtEnd",
        "title": "Add Item at End of File",
        "category": "ChronoArchive"
      },
      {
        "command": "chronoarchive.deleteItem",
        "title": "Delete Current Item",
        "category": "ChronoArchive"
      },
      {
        "command": "chronoarchive.jumpToNextItem",
        "title": "Jump to Next Item",
        "category": "ChronoArchive"
      },
      {
        "command": "chronoarchive.jumpToPreviousItem",
        "title": "Jump to Previous Item",
        "category": "ChronoArchive"
      },
      {
        "command": "chronoarchive.toggleDoneCycle",
        "title": "Cycle Done Flags",
        "category": "ChronoArchive"
      },
      {
        "command": "chronoarchive.toggleClosedCycle",
        "title": "Cycle Closed Flags",
        "category": "ChronoArchive"
      },
      {
        "command": "chronoarchive.togglePendingCycle",
        "title": "Cycle Pending Flags",
        "category": "ChronoArchive"
      },
      {
        "command": "chronoarchive.toggleImportanceCycle",
        "title": "Cycle Importance Flags",
        "category": "ChronoArchive"
      },
      {
        "command": "chronoarchive.toggleAttentionCycle",
        "title": "Cycle Attention Flags",
        "category": "ChronoArchive"
      },
      {
        "command": "chronoarchive.toggleDrinkCycle",
        "title": "Cycle Drink Flags",
        "category": "ChronoArchive"
      },
      {
        "command": "chronoarchive.toggleGoodEmotionCycle",
        "title": "Cycle Good Emotion Flags",
        "category": "ChronoArchive"
      },
      {
        "command": "chronoarchive.toggleBadEmotionCycle",
        "title": "Cycle Bad Emotion Flags",
        "category": "ChronoArchive"
      },
      {
        "command": "chronoarchive.openDailyLog",
        "title": "Open Daily Log",
        "category": "ChronoArchive"
      }
    ],
    "configuration": {
      "title": "ChronoArchive",
      "properties": {
        "chronoarchive.blankLinesBetweenItems": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "maximum": 3,
          "description": "Number of blank lines to preserve between items. Extra blank lines will be removed."
        },
        "chronoarchive.dailyLogsRoot": {
          "type": "string",
          "default": "",
          "description": "Root folder for daily log files. File path: <root>/YEAR/YEAR-MONTH/YEAR-MONTH-DAY.car. Empty = platform default: Linux: XDG_DOCUMENTS_DIR or ~/Documents, then 'Daily Logs'; Windows: %USERPROFILE%\\Documents\\Daily Logs"
        },
        "chronoarchive.dailyLogTemplatePath": {
          "type": "string",
          "default": "",
          "description": "Path to a custom template file for new daily logs. Use placeholders {{CREATION}} and {{TIME}}. Leave blank to use the built-in default template."
        }
      }
    },
    "keybindings": [
      {
        "command": "chronoarchive.toggleDoneCycle",
        "key": "ctrl+/",
        "when": "editorTextFocus && editorLangId == chronoarchive"
      },
      {
        "command": "chronoarchive.toggleDrinkCycle",
        "key": "ctrl+shift+2",
        "when": "editorTextFocus && editorLangId == chronoarchive"
      },
      {
        "command": "chronoarchive.toggleGoodEmotionCycle",
        "key": "ctrl+shift+0",
        "when": "editorTextFocus && editorLangId == chronoarchive"
      },
      {
        "command": "chronoarchive.toggleBadEmotionCycle",
        "key": "ctrl+shift+9",
        "when": "editorTextFocus && editorLangId == chronoarchive"
      },
      {
        "command": "chronoarchive.toggleClosedCycle",
        "key": "ctrl+'",
        "when": "editorTextFocus && editorLangId == chronoarchive"
      },
      {
        "command": "chronoarchive.togglePendingCycle",
        "key": "ctrl+shift+/",
        "when": "editorTextFocus && editorLangId == chronoarchive"
      },
      {
        "command": "chronoarchive.toggleImportanceCycle",
        "key": "ctrl+shift+\\",
        "when": "editorTextFocus && editorLangId == chronoarchive"
      },
      {
        "command": "chronoarchive.toggleAttentionCycle",
        "key": "ctrl+shift+'",
        "when": "editorTextFocus && editorLangId == chronoarchive"
      },
      {
        "command": "-editor.action.quickFix",
        "key": "ctrl+1",
        "when": "editorTextFocus && editorLangId == chronoarchive"
      },
      {
        "command": "chronoarchive.setPriority1",
        "key": "ctrl+1",
        "when": "editorTextFocus && editorLangId == chronoarchive"
      },
      {
        "command": "chronoarchive.setPriority2",
        "key": "ctrl+2",
        "when": "editorTextFocus && editorLangId == chronoarchive"
      },
      {
        "command": "chronoarchive.setPriority3",
        "key": "ctrl+3",
        "when": "editorTextFocus && editorLangId == chronoarchive"
      },
      {
        "command": "chronoarchive.setPriority4",
        "key": "ctrl+4",
        "when": "editorTextFocus && editorLangId == chronoarchive"
      },
      {
        "command": "chronoarchive.setPriority5",
        "key": "ctrl+5",
        "when": "editorTextFocus && editorLangId == chronoarchive"
      },
      {
        "command": "chronoarchive.moveItemUp",
        "key": "alt+k",
        "when": "editorTextFocus && editorLangId == chronoarchive"
      },
      {
        "command": "chronoarchive.moveItemDown",
        "key": "alt+j",
        "when": "editorTextFocus && editorLangId == chronoarchive"
      },
      {
        "command": "chronoarchive.moveLineUp",
        "key": "alt+up",
        "when": "editorTextFocus && editorLangId == chronoarchive"
      },
      {
        "command": "chronoarchive.moveLineDown",
        "key": "alt+down",
        "when": "editorTextFocus && editorLangId == chronoarchive"
      },
      {
        "command": "chronoarchive.addItemAfter",
        "key": "ctrl+p",
        "when": "editorTextFocus && editorLangId == chronoarchive"
      },
      {
        "command": "chronoarchive.addItemBefore",
        "key": "ctrl+shift+p",
        "when": "editorTextFocus && editorLangId == chronoarchive"
      },
      {
        "command": "chronoarchive.addItemAtEnd",
        "key": "ctrl+alt+=",
        "when": "editorTextFocus && editorLangId == chronoarchive"
      },
      {
        "command": "chronoarchive.deleteItem",
        "key": "ctrl+shift+delete",
        "when": "editorTextFocus && editorLangId == chronoarchive"
      },
      {
        "command": "chronoarchive.jumpToNextItem",
        "key": "ctrl+j",
        "when": "editorTextFocus && editorLangId == chronoarchive"
      },
      {
        "command": "chronoarchive.jumpToPreviousItem",
        "key": "ctrl+k",
        "when": "editorTextFocus && editorLangId == chronoarchive"
      },
      {
        "command": "chronoarchive.openDailyLog",
        "key": "ctrl+alt+d",
        "when": "editorTextFocus"
      },
      {
        "command": "chronoarchive.openDailyLog",
        "key": "alt+meta+d",
        "when": "editorTextFocus"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "pnpm run bundle",
    "compile": "tsc -p ./",
    "bundle": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "vsce package --no-dependencies",
    "pretest": "pnpm run compile && pnpm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.1",
    "@types/node": "16.x",
    "@types/vscode": "^1.75.0",
    "@typescript-eslint/eslint-plugin": "^5.45.0",
    "@typescript-eslint/parser": "^5.45.0",
    "@vscode/test-electron": "^2.2.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.27.3",
    "eslint": "^8.28.0",
    "glob": "^8.0.3",
    "mocha": "^10.1.0",
    "typescript": "^4.9.3"
  },
  "dependencies": {
    "vscode-languageclient": "^8.1.0"
  }
}
